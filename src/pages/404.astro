---
import { Font } from 'astro:assets';
import '../styles/global.css';
import logoSrc from '../assets/logo.svg?url';
import githubSrc from '../assets/icons/github.svg?url';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="icon" href={`${base}/favicon.ico`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#509080" />
    <meta name="generator" content={Astro.generator} />
    <title>404 – ISHII YUSUKE</title>
    <Font cssVariable="--font-line-seed-jp" preload />
    <Font cssVariable="--font-inter-gf" preload />
    <Font cssVariable="--font-figtree-gf" preload />
    <Font cssVariable="--font-montserrat-gf" preload />
  </head>
  <body class="grid min-h-dvh grid-rows-[auto_1fr_auto] bg-white">
    <header class="px-6 py-8 md:px-12 md:py-10">
      <div class="mx-auto w-full max-w-312">
        <nav class="flex items-center justify-between">
          <a href={`${base}/`}>
            <img src={logoSrc} alt="ISHII YUSUKE" class="h-10 w-auto md:h-14" />
          </a>
          <a
            href="https://github.com/yusk-ishii"
            target="_blank"
            rel="noopener noreferrer"
            class="block h-10 w-10 md:h-14 md:w-14"
            aria-label="GitHub"
          >
            <img src={githubSrc} alt="" aria-hidden="true" class="h-auto w-full" />
          </a>
        </nav>
      </div>
    </header>

    <main class="flex w-full items-center">
      <section class="w-full px-6 py-5 md:px-12 md:py-10">
        <div class="mx-auto flex w-full max-w-312 flex-col items-center gap-10">
          <!-- 404 notice -->
          <div class="flex flex-col items-center gap-3 text-center">
            <p class="font-montserrat text-grey-300 text-xl font-medium tracking-[0.2em]">
              404 NOT FOUND
            </p>
            <p class="text-grey-600 text-xl leading-[1.6]">ページが見つかりませんでした</p>
          </div>

          <!-- Game -->
          <div class="flex flex-col items-center gap-5">
            <div id="game-wrapper" class="relative" style="width:280px; cursor:pointer;">
              <canvas
                id="stack-canvas"
                style="display:block; width:280px; height:420px; border-radius:16px;"></canvas>
            </div>

            <!-- Score -->
            <div class="flex items-center gap-10">
              <div class="text-center">
                <p class="font-figtree text-grey-300 mb-1 text-xs leading-none">SCORE</p>
                <p
                  id="score-display"
                  class="font-figtree text-grey-600 text-3xl leading-none font-bold"
                >
                  0
                </p>
              </div>
              <div class="text-center">
                <p class="font-figtree text-grey-300 mb-1 text-xs leading-none">BEST</p>
                <p
                  id="best-display"
                  class="font-figtree text-grey-600 text-3xl leading-none font-bold"
                >
                  0
                </p>
              </div>
            </div>
          </div>

          <a
            href={`${base}/`}
            class="font-figtree bg-grey-600 flex items-center gap-2 rounded-full px-6 py-3.5 text-sm font-bold text-white transition-opacity duration-200 ease-out hover:opacity-70"
          >
            トップへ戻る
          </a>
        </div>
      </section>
    </main>

    <footer class="flex items-center justify-center py-8 md:py-10">
      <p class="text-grey-500 text-[10px] leading-none whitespace-nowrap">©2026 ISHII YUSUKE</p>
    </footer>
  </body>
</html>

<style>
  #game-wrapper {
    touch-action: manipulation;
    user-select: none;
  }
</style>

<script>
  type State = 'idle' | 'playing' | 'over';

  const canvas = document.getElementById('stack-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const wrapper = document.getElementById('game-wrapper')!;
  const scoreEl = document.getElementById('score-display')!;
  const bestEl = document.getElementById('best-display')!;

  // Canvas
  const W = 280,
    H = 420;
  const DPR = Math.min(window.devicePixelRatio || 1, 2);
  canvas.width = W * DPR;
  canvas.height = H * DPR;
  ctx.scale(DPR, DPR);

  // Constants
  const BH = 30;
  const GAP = 5;
  const STEP = BH + GAP;
  const INIT_W = W * 0.62;
  const BASE_Y = H - BH - 24;
  const INIT_SPD = 1.5;
  const PERF_PX = 3;
  const RADIUS = 5;

  // Colors
  const BG = '#f5f5f5';
  const CLR: Record<number, string> = {};
  function blockColor(i: number) {
    if (i === 0) return '#333333';
    return i % 2 === 1 ? '#68b9a4' : '#509080';
  }
  void CLR;

  function rawY(i: number) {
    return BASE_Y - i * STEP;
  }

  interface Blk {
    x: number;
    w: number;
    i: number;
  }
  interface Piece {
    x: number;
    w: number;
    y: number;
    vy: number;
    alpha: number;
    clr: string;
  }

  let state: State = 'idle';
  let blks: Blk[] = [];
  let mv = { x: 0, w: 0, dir: 1, spd: INIT_SPD };
  let pts: Piece[] = [];
  let score = 0;
  let best = parseInt(localStorage.getItem('stack-best') || '0');
  let scrollY = 0,
    scrollTarget = 0;
  let flash = 0;

  bestEl.textContent = String(best);

  function init() {
    blks = [{ x: (W - INIT_W) / 2, w: INIT_W, i: 0 }];
    pts = [];
    score = 0;
    scrollY = scrollTarget = 0;
    flash = 0;
    spawnMv();
    state = 'playing';
    scoreEl.textContent = '0';
  }

  function spawnMv() {
    const last = blks[blks.length - 1];
    mv = { x: 0, w: last.w, dir: 1, spd: Math.min(INIT_SPD + score * 0.1, 6) };
  }

  function drop() {
    const last = blks[blks.length - 1];
    const ni = last.i + 1;
    const ry = rawY(ni);
    const clr = blockColor(ni);

    const ol = Math.max(mv.x, last.x);
    const or_ = Math.min(mv.x + mv.w, last.x + last.w);
    const ow = or_ - ol;

    if (ow <= 0) {
      pts.push({ x: mv.x, w: mv.w, y: ry, vy: 1, alpha: 1, clr });
      gameOver();
      return;
    }

    const perfect = Math.abs(ow - last.w) <= PERF_PX;
    const nx = perfect ? last.x : ol;
    const nw = perfect ? last.w : ow;

    if (!perfect) {
      if (mv.x < last.x) pts.push({ x: mv.x, w: last.x - mv.x, y: ry, vy: 0, alpha: 1, clr });
      if (mv.x + mv.w > last.x + last.w)
        pts.push({
          x: last.x + last.w,
          w: mv.x + mv.w - last.x - last.w,
          y: ry,
          vy: 0,
          alpha: 1,
          clr,
        });
    } else {
      flash = 22;
    }

    blks.push({ x: nx, w: nw, i: ni });
    score++;
    if (score > best) {
      best = score;
      localStorage.setItem('stack-best', String(best));
      bestEl.textContent = String(best);
    }
    scoreEl.textContent = String(score);

    scrollTarget = Math.max(scrollTarget, H * 0.28 - rawY(ni + 1));
    spawnMv();
  }

  function gameOver() {
    state = 'over';
  }

  function update() {
    mv.x += mv.dir * mv.spd;
    if (mv.x + mv.w > W) {
      mv.x = W - mv.w;
      mv.dir = -1;
    } else if (mv.x < 0) {
      mv.x = 0;
      mv.dir = 1;
    }

    pts.forEach((p) => {
      p.vy += 0.35;
      p.y += p.vy;
      p.alpha -= 0.03;
    });
    pts = pts.filter((p) => p.alpha > 0);

    scrollY += (scrollTarget - scrollY) * 0.1;
    if (flash > 0) flash--;
  }

  function render() {
    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = BG;
    ctx.fillRect(0, 0, W, H);

    if (flash > 0) {
      ctx.fillStyle = `rgba(104,185,164,${(flash / 22) * 0.22})`;
      ctx.fillRect(0, 0, W, H);
    }

    ctx.save();
    ctx.translate(0, scrollY);

    blks.forEach((b) => {
      ctx.fillStyle = blockColor(b.i);
      rr(b.x, rawY(b.i), b.w, BH);
    });

    if (state === 'playing') {
      const last = blks[blks.length - 1];
      ctx.fillStyle = blockColor(blks.length);
      rr(mv.x, rawY(last.i + 1), mv.w, BH);
    }

    pts.forEach((p) => {
      ctx.globalAlpha = p.alpha;
      ctx.fillStyle = p.clr;
      rr(p.x, p.y, p.w, BH);
      ctx.globalAlpha = 1;
    });

    ctx.restore();

    // Game over overlay
    if (state === 'over') {
      ctx.fillStyle = 'rgba(245,245,245,0.88)';
      ctx.fillRect(0, 0, W, H);

      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';

      ctx.fillStyle = '#333333';
      ctx.font = 'bold 72px Figtree, sans-serif';
      ctx.fillText(String(score), W / 2, H / 2 - 28);

      ctx.fillStyle = '#9b9b9b';
      ctx.font = '14px Figtree, sans-serif';
      ctx.fillText('タップして再挑戦', W / 2, H / 2 + 36);
    }
  }

  function rr(x: number, y: number, w: number, h: number) {
    const r = Math.min(RADIUS, w / 2);
    ctx.beginPath();
    ctx.roundRect(x, y, w, h, r);
    ctx.fill();
  }

  function loop() {
    if (state === 'playing') update();
    render();
    requestAnimationFrame(loop);
  }

  wrapper.addEventListener('click', () => {
    if (state !== 'playing') init();
    else drop();
  });

  loop();
  init();
</script>
