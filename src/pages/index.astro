---
import '../styles/global.css';

const workCards = [
  {
    tags: 'Web Design, Development',
    title: 'Calm Coffee',
    description: '"静けさ"をコンセプトにした、七里ヶ浜にある喫茶店のWebサイト',
  },
  {
    tags: 'Web Design, Development',
    title: 'Calm Coffee',
    description: '"静けさ"をコンセプトにした、七里ヶ浜にある喫茶店のWebサイト',
  },
  {
    tags: 'Web Design, Development',
    title: 'Calm Coffee',
    description: '"静けさ"をコンセプトにした、七里ヶ浜にある喫茶店のWebサイト',
  },
  {
    tags: 'Web Design, Development',
    title: 'Calm Coffee',
    description: '"静けさ"をコンセプトにした、七里ヶ浜にある喫茶店のWebサイト',
  },
