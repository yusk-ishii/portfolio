---
import { getCollection } from 'astro:content';
import { Font } from 'astro:assets';
import '../styles/global.css';
import WorkCard from '../components/WorkCard.astro';
import WorkPopup from '../components/WorkPopup.astro';
import logoSrc from '../assets/logo.svg?url';
import githubSrc from '../assets/icons/github.svg?url';
import profileSvgSrc from '../assets/profile.svg?url';
import profileIllustSrc from '../assets/profile-illust.svg?url';

const works = (await getCollection('works')).sort((a, b) => a.data.order - b.data.order);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="icon" href={`${base}/favicon.ico`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#509080" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="石井 佑典（Ishii Yusuke）のポートフォリオ。Web Design / UX Design / Frontend Development。"
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://yusk-ishii.github.io/portfolio/" />
    <meta property="og:title" content="ISHII YUSUKE" />
    <meta
      property="og:description"
      content="石井 佑典（Ishii Yusuke）のポートフォリオ。Web Design / UX Design / Frontend Development。"
    />
    <meta property="og:image" content="https://yusk-ishii.github.io/portfolio/ogp.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <title>ISHII YUSUKE</title>
    <Font cssVariable="--font-line-seed-jp" preload />
    <Font cssVariable="--font-inter-gf" preload />
    <Font cssVariable="--font-figtree-gf" preload />
    <Font cssVariable="--font-montserrat-gf" preload />
  </head>
  <body class="bg-white">
    <!-- Header -->
    <header class="px-6 py-8 md:px-12 md:py-10">
      <div class="mx-auto w-full max-w-312">
        <nav class="flex items-center justify-between">
          <img src={logoSrc} alt="ISHII YUSUKE" class="h-10 w-auto md:h-14" />
          <a
            href="https://github.com/yusk-ishii"
            target="_blank"
            rel="noopener noreferrer"
            class="block h-10 w-10 md:h-14 md:w-14"
            aria-label="GitHub"
          >
            <img src={githubSrc} alt="" aria-hidden="true" class="h-auto w-full" />
          </a>
        </nav>
      </div>
    </header>

    <main>
      <!-- Work Section -->
      <section class="px-6 pt-8 pb-10 md:px-12 md:pt-12 md:pb-20">
        <div class="mx-auto w-full max-w-312">
          <!-- Section header -->
          <div class="mb-10 flex items-center gap-3 md:mb-16 md:gap-4">
            <div class="h-5 w-5 shrink-0 rounded-full bg-green-400 md:h-6 md:w-6"></div>
            <h2
              class="font-montserrat text-grey-600 text-2xl leading-none font-medium whitespace-nowrap md:text-[32px]"
            >
              Personal Work
            </h2>
          </div>

          <!-- Work cards grid -->
          <div
            class="grid grid-cols-1 gap-y-10 min-[1000px]:grid-cols-2 min-[1000px]:gap-x-[4%] min-[1000px]:gap-y-12"
          >
            {works.map((entry) => <WorkCard entry={entry} />)}
          </div>
        </div>
      </section>

      <!-- Profile Section -->
      <section class="px-6 pt-10 pb-16 md:px-12 md:py-20">
        <div class="mx-auto w-full max-w-312">
          <div
            class="flex flex-col gap-8 min-[1000px]:flex-row min-[1000px]:items-start min-[1000px]:gap-[8%]"
          >
            <!-- Left: Profile info -->
            <div class="flex min-w-0 flex-1 flex-col gap-8 md:gap-10 md:self-stretch">
              <img
                src={profileSvgSrc}
                alt="Profile"
                class="h-12 w-auto object-contain object-left md:h-15"
                style="max-width: 251px;"
              />
              <p class="text-grey-600 text-2xl leading-[1.8] md:text-[32px]">
                石井 佑典 / Ishii Yusuke
              </p>
              <div
                class="text-grey-600 flex flex-col gap-6 text-sm leading-[1.8] md:gap-8 md:text-base"
              >
                <p>
                  フロントエンドエンジニアとして8年間、デザインを形にする仕事に携わってきました。その中で「なぜこのUIになっているのか」「なぜこの体験の順番なのか」という問いが積み重なり、デザインの上流から考えることへの興味が生まれました。
                </p>
                <p>
                  特に関心があるのは感情導線の設計です。ユーザーが最初に受ける印象から、情報の読まれ方、行動へのきっかけまで、どのような順番で何を感じるのかを考えながら体験を設計することに魅力を感じています。フロントエンドとして培った実装経験を活かし、コンセプトから実装まで一貫して体験を形にすることを大切にしています。
                </p>
              </div>
            </div>

            <!-- Right: Photo -->
            <div
              class="bg-grey-100 aspect-4/3 min-w-0 flex-1 overflow-hidden rounded-xl min-[1000px]:aspect-auto min-[1000px]:h-148 md:rounded-2xl"
            >
              <img
                src={profileIllustSrc}
                alt="石井 佑典"
                class="h-full w-full object-contain min-[1000px]:object-cover"
              />
            </div>
          </div>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="flex items-center justify-center py-8 md:py-10">
      <p class="text-grey-500 text-[10px] leading-none whitespace-nowrap">©2026 ISHII YUSUKE</p>
    </footer>

    <WorkPopup works={works} />
  </body>
</html>
