---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import githubIconSrc from '../assets/icons/github.svg?url';
import arrowIconSrc from '../assets/icons/arrow-up-right.svg?url';
import closeIconSrc from '../assets/icons/close.svg?url';

interface Props {
  works: CollectionEntry<'works'>[];
}

const { works } = Astro.props;

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/works/**/*.{jpg,jpeg,png,webp}',
  { eager: true },
);

const allVideos = import.meta.glob<{ default: string }>('/src/assets/works/**/*.{mp4,webm}', {
  eager: true,
});

function resolveImage(id: string, path: string | undefined) {
  if (!path) return undefined;
  const key = `/src/assets/works/${id}/${path.replace('./', '')}`;
  return allImages[key]?.default;
}

function resolveVideo(id: string, path: string | undefined) {
  if (!path) return undefined;
  const base = path.replace('./', '').replace(/\.(mp4|webm)$/, '');
  return {
    mp4: allVideos[`/src/assets/works/${id}/${base}.mp4`]?.default,
    webm: allVideos[`/src/assets/works/${id}/${base}.webm`]?.default,
  };
}
---

<div
  id="popup"
  class="fixed inset-0 z-50 overflow-y-auto overscroll-none"
  role="dialog"
  aria-modal="true"
  aria-label="プロジェクト詳細"
>
  <div
    id="popup-bg"
    class="pointer-events-none fixed inset-0 bg-black/20 backdrop-blur-sm"
    aria-hidden="true"
  >
  </div>
  <div
    class="relative flex min-h-full justify-center px-6 py-10 md:px-12 md:py-20"
    id="popup-overlay"
  >
    <div
      id="popup-content"
      class="relative flex w-full max-w-312 flex-col items-center self-start rounded-lg bg-white px-5 py-16 md:rounded-2xl md:px-12 md:py-20"
    >
      <!-- Close button -->
      <button
        id="popup-close"
        class="absolute top-4 right-4 flex h-8 w-8 cursor-pointer items-center justify-center rounded-full text-[#333] transition-opacity hover:opacity-60 md:top-8 md:right-8 md:h-10 md:w-10"
        aria-label="閉じる"
        type="button"
      >
        <img src={closeIconSrc} class="h-full w-full" alt="" aria-hidden="true" />
      </button>

      <!-- One panel per work, statically rendered by Astro -->
      {
        works.map((w) => {
          const heroSrc = resolveImage(w.id, w.data.heroImage);
          return (
            <div data-popup-panel={w.id} class="w-full flex-col items-center gap-10 md:max-w-5xl">
              {/* Title area */}
              <div class="flex w-full flex-col items-center gap-16">
                <div class="flex w-full flex-col items-start gap-10">
                  {/* Title block + meta */}
                  <div class="flex w-full flex-col items-start gap-10 md:gap-32">
                    <div class="flex flex-col items-start gap-5 text-[#333]">
                      <p class="text-[40px] leading-none font-bold md:text-[80px]">
                        {w.data.title}
                      </p>
                      <p class="text-base leading-[1.4] md:text-[21px]">{w.data.description}</p>
                    </div>

                    {/* Meta + Buttons */}
                    <div class="flex w-full flex-col items-start gap-7 md:items-end">
                      <div class="font-figtree flex w-full flex-col items-start gap-4 text-base font-bold whitespace-nowrap min-[1000px]:flex-row min-[1000px]:items-center min-[1000px]:justify-end min-[1000px]:gap-8">
                        {w.data.date && (
                          <div class="flex flex-col items-start gap-2">
                            <p class="leading-[1.4] text-[#9b9b9b]">Date</p>
                            <p class="leading-[1.4] text-[#333]">{w.data.date}</p>
                          </div>
                        )}
                        {w.data.scope && (
                          <div class="flex flex-col items-start gap-2">
                            <p class="leading-[1.4] text-[#9b9b9b]">Scope</p>
                            <p class="leading-[1.4] wrap-break-word whitespace-normal text-[#333]">
                              {w.data.scope}
                            </p>
                          </div>
                        )}
                        {w.data.stack && (
                          <div class="flex flex-col items-start gap-2">
                            <p class="leading-[1.4] text-[#9b9b9b]">Stack</p>
                            <p class="leading-[1.4] wrap-break-word whitespace-normal text-[#333]">
                              {w.data.stack}
                            </p>
                          </div>
                        )}
                      </div>
                      {(w.data.github || w.data.website) && (
                        <div class="flex w-full flex-col gap-3 min-[1000px]:w-auto min-[1000px]:flex-row min-[1000px]:items-center">
                          {w.data.github && (
                            <a
                              href={w.data.github}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="font-figtree flex w-full items-center justify-center gap-2 rounded-full border border-[#333] px-5 py-[14px] text-sm font-bold text-[#333] transition-opacity hover:opacity-70 min-[1000px]:w-auto"
                            >
                              <img src={githubIconSrc} class="h-5 w-5" alt="" aria-hidden="true" />
                              View on GitHub
                            </a>
                          )}
                          {w.data.website && (
                            <a
                              href={w.data.website}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="font-figtree flex w-full items-center justify-center gap-2 rounded-full bg-[#333] px-5 py-[14px] text-sm font-bold text-white transition-opacity hover:opacity-70 min-[1000px]:w-auto"
                            >
                              Visit Website
                              <img
                                src={arrowIconSrc}
                                class="h-5 w-5 brightness-0 invert"
                                alt=""
                                aria-hidden="true"
                              />
                            </a>
                          )}
                        </div>
                      )}
                    </div>
                  </div>

                  {/* Hero image */}
                  {heroSrc ? (
                    <Image
                      src={heroSrc}
                      alt={w.data.title}
                      class="aspect-[1.618/1] w-full rounded-lg object-cover md:rounded-2xl"
                      format="webp"
                    />
                  ) : (
                    <div class="aspect-[1.618/1] w-full rounded-lg bg-[#d9d9d9] md:rounded-2xl" />
                  )}
                </div>

                {/* Overview */}
                {w.data.overview && (
                  <div class="flex w-full flex-col items-start gap-6 md:max-w-220 md:flex-row md:gap-[8%]">
                    <p class="shrink-0 text-xl leading-none font-bold text-[#333] md:text-[26px]">
                      Overview
                    </p>
                    <p class="flex-1 text-sm leading-[1.8] text-[#333] md:text-base">
                      {w.data.overview}
                    </p>
                  </div>
                )}
              </div>

              {/* Sections */}
              {w.data.sections.length > 0 && (
                <div class="flex w-full flex-col items-center gap-16 px-0 py-10 min-[768px]:gap-20 min-[1200px]:gap-32 min-[1200px]:px-16 md:py-20">
                  {w.data.sections.map((section) => {
                    const sectionSrc = resolveImage(w.id, section.image);
                    const sectionVideo = resolveVideo(w.id, section.video);
                    return (
                      <div class="flex w-full flex-col items-center gap-10 md:max-w-220 md:gap-16">
                        <div class="flex w-full flex-col items-start px-0 min-[768px]:px-8 min-[1200px]:px-16">
                          <div class="flex w-full flex-col items-start gap-6 text-[#333] md:gap-10">
                            <div class="w-full text-xl leading-[1.6] font-bold md:text-[32px]">
                              {section.heading
                                .trim()
                                .split('\n')
                                .map((line) => (
                                  <p>{line}</p>
                                ))}
                            </div>
                            <div class="flex flex-col gap-4 text-sm leading-[1.8] md:text-base">
                              {section.body.map((p) => (
                                <p>{p}</p>
                              ))}
                            </div>
                          </div>
                        </div>
                        {sectionVideo?.mp4 || sectionVideo?.webm ? (
                          <video class="w-full" muted loop playsinline data-autoplay-video>
                            {sectionVideo.webm && (
                              <source src={sectionVideo.webm} type="video/webm" />
                            )}
                            {sectionVideo.mp4 && <source src={sectionVideo.mp4} type="video/mp4" />}
                          </video>
                        ) : sectionSrc ? (
                          <div class="w-full rounded-lg bg-[#F5F5F5] px-8 py-12 min-[1200px]:px-16 md:rounded-2xl">
                            <Image src={sectionSrc} alt="" class="w-full" format="webp" />
                          </div>
                        ) : (
                          <div class="aspect-[1.618/1] w-full rounded-lg bg-[#d9d9d9] md:rounded-2xl" />
                        )}
                      </div>
                    );
                  })}
                </div>
              )}
            </div>
          );
        })
      }
    </div>
  </div>
</div>

<style>
  #popup {
    scrollbar-width: none;
  }
  #popup::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  const popup = document.getElementById('popup')!;
  const popupContent = document.getElementById('popup-content')!;
  const popupOverlay = document.getElementById('popup-overlay')!;
  const closeBtn = document.getElementById('popup-close')!;

  function openPopup(slug: string) {
    document.querySelectorAll<HTMLElement>('[data-popup-panel]').forEach((p) => {
      p.classList.remove('is-open');
    });
    const panel = document.querySelector<HTMLElement>(`[data-popup-panel="${slug}"]`);
    if (!panel) return;
    panel.classList.add('is-open');

    popup.classList.remove('is-closing');
    popup.classList.add('is-open');
    popup.scrollTop = 0;
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        popupContent.classList.add('is-entering');
      });
    });
  }

  function closePopup() {
    popup.classList.add('is-closing');
    popupContent.classList.remove('is-entering');
    function onTransitionEnd(e: TransitionEvent) {
      if (e.propertyName !== 'transform') return;
      popupContent.removeEventListener('transitionend', onTransitionEnd);
      popup.classList.remove('is-open', 'is-closing');
    }
    popupContent.addEventListener('transitionend', onTransitionEnd);
  }

  document.querySelectorAll<HTMLElement>('[data-work-card]').forEach((card) => {
    card.addEventListener('click', () => {
      const slug = card.dataset.workSlug;
      if (slug) openPopup(slug);
    });
  });

  closeBtn.addEventListener('click', closePopup);

  popupOverlay.addEventListener('click', (e) => {
    if (!popupContent.contains(e.target as Node)) closePopup();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && popup.classList.contains('is-open')) closePopup();
  });

  const videoObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const video = entry.target as HTMLVideoElement;
        if (entry.isIntersecting) {
          video.play();
        } else {
          video.pause();
        }
      });
    },
    { threshold: 0.3 },
  );

  document.querySelectorAll<HTMLVideoElement>('[data-autoplay-video]').forEach((video) => {
    videoObserver.observe(video);
  });
</script>
